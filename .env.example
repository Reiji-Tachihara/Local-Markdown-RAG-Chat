# バックエンド設定（Local Markdown RAG Chat）。
# サーバを起動する前に、このファイルを .env にコピーする。

# ローカル LLM の API エンドポイント。
OLLAMA_BASE_URL=http://localhost:11434/api

# true の場合、外部公開されたホストなどローカル以外の接続先を拒否する。
ENFORCE_LOCAL_OLLAMA=true

# /api/chat で使う回答生成モデル。
OLLAMA_CHAT_MODEL=qwen3:8b

# インデックス作成と類似検索で使う embedding モデル。
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Ollama API の応答待ち秒数。長い質問でタイムアウトする場合は増やす。
OLLAMA_REQUEST_TIMEOUT=180

# ollama: ローカル LLM の embedding を使う。
# hash: 疎通確認に使える決定的なローカル代替実装。
EMBEDDING_BACKEND=ollama
HASH_EMBEDDING_DIMENSIONS=384

# 知識ベースとローカル実行データ。
KNOWLEDGE_DIR=knowledge
DATA_DIR=data
DATABASE_PATH=data/app.db

# 読み込み時の chunk 分割設定。
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RETRIEVAL_LIMIT=4

# チャット入力と LLM に渡す RAG 文脈の上限。
CHAT_MESSAGE_MAX_CHARS=12000
RAG_CONTEXT_MAX_CHARS=12000

# サーバへのブラウザアクセスを許可するオリジン。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
